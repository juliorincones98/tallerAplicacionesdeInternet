PORT=3000
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# Clave secreta usada por el backend para firmar y validar la sesion del panel admin.
# Debe ser larga, dificil de adivinar y distinta en cada entorno.
# Si cambia, todas las sesiones activas del administrador se invalidan.
ADMIN_SESSION_SECRET=change-this-session-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
